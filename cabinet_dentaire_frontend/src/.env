# ============================================================
# cabinet_dentaire_frontend/.env
# ============================================================
# Toutes les requêtes passent par le gateway (port 8080)
# Ne jamais appeler auth_service (8001) ou api_service (8000) directement
# ============================================================

# URL du gateway — point d'entrée unique pour tout le frontend
VITE_API_BASE_URL=http://localhost:8080

# Nom de l'app (affiché dans le titre)
VITE_APP_NAME=Cabinet Dentaire

# Durée de vie du token en ms (60 min = 3600000)
VITE_TOKEN_REFRESH_THRESHOLD_MS=300000