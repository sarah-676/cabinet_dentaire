# ─────────────────────────────────────────────────────────────
# Cabinet Dentaire Frontend Configuration
# ─────────────────────────────────────────────────────────────
# Copy this file to src/.env and configure for your environment
# Restart dev server after changes: npm run dev

# API Configuration
# URL of the backend gateway or API service
VITE_API_BASE_URL=http://localhost:8080/api

# WebSocket — notifications temps réel (Django Channels sur api_service)
# Exemple : ws://localhost:8000/ws/notifications/
# JWT : ?token=<access> (ajouté automatiquement par le frontend)
VITE_WS_URL=ws://localhost:8000/ws/notifications/

# Build Configuration
VITE_APP_TITLE=Cabinet Dentaire
VITE_APP_VERSION=1.0.0

# Debug Mode (set to 'true' for development)
VITE_DEBUG=false